# Railway Environment Variables Template
# Copy these to your Railway service dashboard under Settings → Variables

# ============================================
# REQUIRED - Database
# ============================================
# Railway automatically provides this if PostgreSQL is added
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ============================================
# REQUIRED - ChromaDB
# ============================================
# Use Railway internal networking URL
CHROMA_HOST=chromadb.railway.internal
CHROMA_PORT=8000

# ============================================
# REQUIRED - Authentication
# ============================================
# Generate a secure random string (e.g., using: openssl rand -hex 32)
JWT_SECRET=your-secret-key-change-in-production-generate-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# ============================================
# REQUIRED - AI Provider (Choose ONE)
# ============================================
# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_COMPLETION_MODEL=gpt-4-turbo-preview
LLM_PROVIDER=openai

# Option 2: DeepSeek (more cost-effective)
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# LLM_PROVIDER=deepseek

# ============================================
# REQUIRED - Application Config
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# Add your frontend domain(s) - update after deploying to Vercel
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://auto-bidder.vercel.app

# ============================================
# OPTIONAL - Email Notifications
# ============================================
# Required only if using autonomous bidding features
# Get API key from: https://resend.com
RESEND_API_KEY=re_your-resend-api-key

# ============================================
# OPTIONAL - Autonomous Features
# ============================================
AUTO_DISCOVERY_ENABLED=false
AUTO_PROPOSAL_THRESHOLD=0.85

# ============================================
# OPTIONAL - ETL Configuration
# ============================================
ETL_USE_PERSISTENCE=true
HF_ETL_SCHEDULE_HOURS=168
FREELANCER_ETL_SCHEDULE_HOURS=24

# Comma-separated keywords for filtering projects
PROJECT_FILTER_KEYWORDS=python,fastapi,nextjs,react,typescript,nodejs

# ============================================
# OPTIONAL - File Processing
# ============================================
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================
# OPTIONAL - Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# OPTIONAL - Advanced Model Configuration
# ============================================
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
DISABLE_MODEL_SOURCE_CHECK=true
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real secrets to Git
# 2. Copy values to Railway dashboard manually
# 3. Use Railway's variable references: ${{Postgres.DATABASE_URL}}
# 4. Internal service URLs: service-name.railway.internal
# 5. Generate secure JWT_SECRET: openssl rand -hex 32
