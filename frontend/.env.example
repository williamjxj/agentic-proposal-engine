# Backend API URL (default for local development)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000

# Python AI Service URL (default for local development)
PYTHON_AI_SERVICE_URL=http://localhost:8000

# Demo User (optional - enables "Try as demo user" on login/signup)
# NEXT_PUBLIC_DEMO_EMAIL=jxjwilliam@2925.com
# NEXT_PUBLIC_DEMO_PASSWORD=your-demo-password

# Workflow Optimization Settings
NEXT_PUBLIC_AUTO_SAVE_INTERVAL_MS=10000
NEXT_PUBLIC_OFFLINE_SYNC_RETRY_MS=5000
NEXT_PUBLIC_ENABLE_KEYBOARD_SHORTCUTS=true
NEXT_PUBLIC_VIRTUAL_SCROLL_THRESHOLD=100

