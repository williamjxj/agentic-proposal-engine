# OpenAI Configuration (Optional - if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM Provider Configuration
LLM_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_TEMPERATURE=0.5
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=4096

# Database Configuration (PostgreSQL from docker-compose)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/auto_bidder_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Application Settings
LOG_LEVEL=INFO
DATA_DIR=data
DISABLE_MODEL_SOURCE_CHECK=True
ENCRYPTION_KEY=your-encryption-key-here

# Session and Draft Settings
SESSION_STATE_TTL_HOURS=24
DRAFT_RETENTION_HOURS=24
MAX_DRAFT_SIZE_KB=1000
ENABLE_WORKFLOW_ANALYTICS=true

# HuggingFace Dataset Configuration (Mock data for development)
USE_HF_DATASET=true
HF_DATASET_ID=jacob-hugging-face/job-descriptions
HF_JOB_LIMIT=200

# ETL Persistence (003-projects-etl-persistence)
ETL_USE_PERSISTENCE=false
HF_ETL_SCHEDULE_HOURS=168
FREELANCER_ETL_SCHEDULE_HOURS=24

# Autonomous Bidding (004-improve-autonomous)
AUTO_DISCOVERY_ENABLED=false
RESEND_API_KEY=
AUTO_PROPOSAL_THRESHOLD=0.85

# Email Testing Configuration
# When TEST_MODE=true, all emails are redirected to TEST_EMAIL
# Use this when testing without sending to real customer emails
TEST_MODE=false
TEST_EMAIL=your-email@gmail.com

# Email sender (FROM field) - MUST be from a verified domain in Resend
# IMPORTANT: Always use service@bestitconsulting.ca (verified domain)
# Do NOT change this unless you have verified a different domain with Resend
FROM_EMAIL=service@bestitconsulting.ca

# BCC (Blind Carbon Copy) - automatically send copy of all proposals to this email
# Recommended: Set to your business email to keep archive of sent proposals
# This solves the "missing original email" issue since Resend doesn't store sent emails
# Leave blank to disable BCC feature
BCC_EMAIL=bestitconsultingca@gmail.com

# Proposal submission: default receiver (TO field) when customer email not found
# This can be any valid email address - typically your business email
# Actual customer emails are auto-extracted from job descriptions when available
PROPOSAL_SUBMIT_EMAIL=bestitconsultingca@gmail.com

# Alternative HuggingFace datasets (uncomment to use):
# HF_DATASET_ID=lukebarousse/data_jobs
# HF_DATASET_ID=debasmitamukherjee/IT_job_postings
