# OpenAI Configuration (Optional - if using OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM Provider Configuration
LLM_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_TEMPERATURE=0.5
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=4096

# Database Configuration (PostgreSQL from docker-compose)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/auto_bidder_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Application Settings
LOG_LEVEL=INFO
DATA_DIR=data
DISABLE_MODEL_SOURCE_CHECK=True
ENCRYPTION_KEY=your-encryption-key-here

# Session and Draft Settings
SESSION_STATE_TTL_HOURS=24
DRAFT_RETENTION_HOURS=24
MAX_DRAFT_SIZE_KB=1000
ENABLE_WORKFLOW_ANALYTICS=true

# HuggingFace Dataset Configuration (Mock data for development)
USE_HF_DATASET=true
HF_DATASET_ID=jacob-hugging-face/job-descriptions
HF_JOB_LIMIT=200

# Alternative HuggingFace datasets (uncomment to use):
# HF_DATASET_ID=lukebarousse/data_jobs
# HF_DATASET_ID=debasmitamukherjee/IT_job_postings
